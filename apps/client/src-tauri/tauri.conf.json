{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sisyphean",
  "version": "0.1.0",
  "identifier": "com.sisyphean.client",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sisyphean",
        "width": 460,
        "height": 620,
        "minWidth": 460,
        "minHeight": 620,
        "maxWidth": 460,
        "maxHeight": 620,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "maximized": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "msi", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
